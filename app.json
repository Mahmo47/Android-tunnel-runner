{
  "expo": {
    "name": "Tunnel Runner 3D",
    "slug": "tunnel-runner-3d",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tunnelrunner",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourname.tunnelrunner3d",
      "infoPlist": {
        "NSMotionUsageDescription": "Gyroscope is used to steer your ship in Tunnel Runner 3D."
      }
    },
    "android": {
      "package": "com.yourname.tunnelrunner3d",
      "permissions": [
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-sensors",
        {
          "motionPermission": "Allow Tunnel Runner 3D to access the gyroscope for tilt controls."
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-asset"
    ]
  }
}
